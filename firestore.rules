rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.uid is string &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.points is number &&
             data.reportsCount is number &&
             data.verificationsCount is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    // Validation for Issue entity
    function isValidIssue(data) {
      return data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.category is string &&
             data.severity is number &&
             data.status is string &&
             data.reportedBy is string;
    }

    match /issues/{issueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidIssue(request.resource.data);
      allow update: if isSignedIn() && isValidIssue(request.resource.data);
      allow delete: if false;
    }

    // Validation for Insight entity
    function isValidInsight(data) {
      return data.zone is string &&
             data.prediction is string &&
             data.riskLevel is string;
    }

    match /insights/{insightId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidInsight(request.resource.data);
      allow update: if isSignedIn() && isValidInsight(request.resource.data);
      allow delete: if false;
    }

    match /agentLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
